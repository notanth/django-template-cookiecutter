DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB={{ cookiecutter.project_slug }}
POSTGRES_USER={{ cookiecutter.project_slug }}_user
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://{{ cookiecutter.project_slug }}_user:changeme@db:5432/{{ cookiecutter.project_slug }}  # pragma: allowlist secret

REDIS_URL=redis://redis:6379/0

# Cloudflare R2 — used for media/static via django-storages
# uv add django-storages then configure DEFAULT_FILE_STORAGE in settings.py
CLOUDFLARE_R2_ACCESS_KEY=your-key
CLOUDFLARE_R2_SECRET_KEY=your-secret  # pragma: allowlist secret
CLOUDFLARE_R2_BUCKET=your-bucket

# ADD PROJECT-SPECIFIC ENV VARS HERE e.g:
# STRIPE_SECRET_KEY=your-stripe-key  # pragma: allowlist secret
# SENDGRID_API_KEY=your-sendgrid-key  # pragma: allowlist secret
